    "combatEffectTemplates": [
      {
        "id": "Defensive",
        "description": "Mixin Template. Defines behaviours for an effect that applies modifiers that increase in strength each time the character evades an attack, up to a maximum value.",
        "baseEffectData": {
          "turnText": "statGroup.stacks",
          "descriptionTemplateData": {
            "initialParameters": {
              "maxStacks": "maxStacks"
            },
            "statGroups": {
              "": "stacks"
            }
          },
          "target": "Self",
          "behaviours": [
            {
              "type": "ModifyStats",
